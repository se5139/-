[tool.ruff]
line-length = 120
target-version = "py311"
exclude = [".venv", "outputs", "installer/Output"]

[tool.pytest.ini_options]
testpaths = ["tests", "scripts"]
python_files = ["test_*.py", "*_check.py"]

[tool.mypy]
python_version = "3.11"
ignore_missing_imports = true
warn_unused_ignores = false
