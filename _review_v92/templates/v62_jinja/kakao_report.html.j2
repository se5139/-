<!doctype html>
<html lang="ko">
<head>
  <meta charset="utf-8">
  <title>{{ project_name }} · v62 Jinja Report</title>
  <style>
    body { font-family: Arial, 'Malgun Gothic', sans-serif; background:#f6f8fb; color:#172033; margin:0; padding:28px; }
    .wrap { max-width: 1100px; margin:0 auto; }
    .hero { background:linear-gradient(135deg,#172033,#2563eb,#14b8a6); color:white; border-radius:24px; padding:26px; }
    .card { background:white; border:1px solid #e5e7eb; border-radius:18px; padding:18px; margin-top:16px; box-shadow:0 8px 22px rgba(15,23,42,.06); }
    h1,h2 { margin-top:0; }
    .tag { display:inline-block; background:#eaf2ff; color:#1d4ed8; border-radius:999px; padding:6px 10px; margin:4px; font-weight:700; }
    table { width:100%; border-collapse:collapse; }
    th,td { border-bottom:1px solid #e5e7eb; text-align:left; padding:9px; vertical-align:top; }
    th { background:#f1f5f9; }
    .warn { color:#b45309; }
    .ok { color:#047857; font-weight:700; }
  </style>
</head>
<body>
<div class="wrap">
  <section class="hero">
    <h1>{{ project_name }}</h1>
    <p>v62 Jinja2 템플릿 리포트 · {{ generated_at }}</p>
    <p>스타일 프리셋: <b>{{ style_preset }}</b></p>
  </section>

  <section class="card">
    <h2>콘셉트 요약</h2>
    <p>{{ concept_text }}</p>
  </section>

  <section class="card">
    <h2>선택 제안</h2>
    {% if selected_suggestions %}
      {% for item in selected_suggestions %}<span class="tag">{{ item }}</span>{% endfor %}
    {% else %}
      <p class="warn">선택 제안이 없습니다. 프로그램에서 제안을 선택하면 이 영역에 반영됩니다.</p>
    {% endif %}
  </section>

  <section class="card">
    <h2>온라인/유튜브/메모 기반 추상 트렌드 신호</h2>
    {% if trend_signals %}
      <ul>{% for item in trend_signals %}<li>{{ item }}</li>{% endfor %}</ul>
    {% else %}
      <p>입력된 트렌드 신호가 없습니다. URL, 자막, 메모, ZIP 분석 결과를 추가하면 여기에 정리됩니다.</p>
    {% endif %}
  </section>

  <section class="card">
    <h2>카카오형 제작 계획</h2>
    <table>
      <tr><th>항목</th><th>값</th></tr>
      <tr><td>정지형 기획 수량</td><td>{{ kakao_planning.static_count }}</td></tr>
      <tr><td>움직이는형 기획 수량</td><td>{{ kakao_planning.animated_count }}</td></tr>
      <tr><td>GIF 초안 최소</td><td>{{ kakao_planning.animated_gif_minimum }}</td></tr>
      <tr><td>캔버스</td><td>{{ kakao_planning.canvas }}</td></tr>
      <tr><td>프레임</td><td>{{ kakao_planning.animated_frame_limit }}</td></tr>
    </table>
  </section>

  <section class="card">
    <h2>v61 GIF 미리보기 연결 상태</h2>
    {% if v61_summary.available %}
      <p class="ok">v61 산출물 연결 가능</p>
      <p>정지형 경로: {{ v61_summary.static_preview }}</p>
      <p>움직이는 GIF 후보: {{ v61_summary.animated_previews|length }}개</p>
      <p>24개 계획 수량: {{ v61_summary.plan_count }}</p>
    {% else %}
      <p class="warn">아직 v61 미리보기 산출물이 없습니다. 먼저 51번 메뉴에서 GIF 미리보기를 생성하면 연결됩니다.</p>
    {% endif %}
  </section>

  <section class="card">
    <h2>안전 기준</h2>
    <ul>{% for note in safety_notes %}<li>{{ note }}</li>{% endfor %}</ul>
  </section>
</div>
</body>
</html>
